{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/master-figure-json/v0.1/schema.json",
  "title": "MasterFigureJSON v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "nodes", "edges", "layout", "style"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["diagram_type", "domain", "version", "source"],
      "properties": {
        "diagram_type": {"type": "string"},
        "domain": {"type": "string"},
        "version": {"type": "string"},
        "source": {"type": "string"}
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "label", "ports"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"},
          "type": {"type": "string"},
          "label": {"type": "string"},
          "ports": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          },
          "shape": {"type": "string"},
          "role": {"type": "string"},
          "signs": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "children": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": {"type": "string"},
          "to": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}, "minItems": 1}
            ]
          },
          "type": {"type": "string"},
          "route": {"type": "string"},
          "signal": {"type": "string"},
          "label": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "layout": {
      "type": "object",
      "properties": {
        "direction": {"type": "string"},
        "main_chain": {"type": "array", "items": {"type": "string"}},
        "upper_branches": {
          "type": "array",
          "items": {"type": "array", "items": {"type": "string"}}
        },
        "top_feedback": {"type": "array", "items": {"type": "string"}},
        "bias_nodes": {"type": "array", "items": {"type": "string"}},
        "geometry": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"},
              "w": {"type": "number"},
              "h": {"type": "number"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "style": {
      "type": "object",
      "properties": {
        "theme": {"type": "string"},
        "line_style": {"type": "string"},
        "arrow": {"type": "boolean"},
        "font": {"type": "string"},
        "gain_shape": {"type": "string"},
        "integrator_shape": {"type": "string"},
        "sum_shape": {"type": "string"},
        "quantizer_shape": {"type": "string"},
        "junction_style": {"type": "string"}
      },
      "additionalProperties": true
    }
  }
}
